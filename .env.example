# =============================================================================
# PeptidePal — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.
#
# On Vercel: set these in Project Settings → Environment Variables.
# On AWS: use AWS Secrets Manager or SSM Parameter Store, injected at runtime.
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
# Use connection pooling in production (e.g., PgBouncer or Prisma Accelerate).
# Vercel Postgres provides a pooled URL automatically.
DATABASE_URL="postgresql://user:password@localhost:5432/peptidepal?schema=public"

# --- Redis -------------------------------------------------------------------
# Used for caching (peptide data, sessions) and BullMQ job queues.
# On Vercel: use Upstash Redis (serverless-friendly).
# On AWS: use ElastiCache Redis.
REDIS_URL="redis://localhost:6379"

# --- NextAuth / Auth.js ------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-strong-random-secret-here"
AUTH_URL="http://localhost:3000"

# OAuth providers (optional — leave blank to disable)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Application -------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Vendor Fetcher ----------------------------------------------------------
# Interval in minutes for background data refresh (default: 15)
VENDOR_REFRESH_INTERVAL_MINUTES="15"

# --- Rate Limiting ------------------------------------------------------------
# Max requests per window for public API endpoints
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_SECONDS="60"

# --- Security -----------------------------------------------------------------
# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS="http://localhost:3000"
