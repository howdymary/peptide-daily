// =============================================================================
// PeptidePal — Prisma Schema
// =============================================================================
// Run migrations:
//   npx prisma migrate dev --name init
//   npx prisma generate
//
// Production:
//   npx prisma migrate deploy
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth.js models (required by @auth/prisma-adapter) ───────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Core domain models ──────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  reviews  Review[]

  @@map("users")
}

model Vendor {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  website   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  prices          PeptidePrice[]
  finnrickRatings FinnrickVendorRating[]
  vendorMapping   VendorMapping?

  @@map("vendors")
}

model Peptide {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  category    String?
  sequence    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  prices          PeptidePrice[]
  reviews         Review[]
  finnrickRatings FinnrickVendorRating[]

  @@index([slug])
  @@index([name])
  @@map("peptides")
}

model PeptidePrice {
  id                 String   @id @default(cuid())
  peptideId          String   @map("peptide_id")
  vendorId           String   @map("vendor_id")
  price              Decimal  @db.Decimal(10, 2)
  currency           String   @default("USD") @db.VarChar(3)
  concentration      String
  sku                String
  productUrl         String   @map("product_url")
  availabilityStatus String   @default("in_stock") @map("availability_status")
  lastUpdated        DateTime @default(now()) @map("last_updated")
  createdAt          DateTime @default(now()) @map("created_at")

  peptide Peptide @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([peptideId, vendorId, sku])
  @@index([peptideId])
  @@index([vendorId])
  @@index([price])
  @@map("peptide_prices")
}

model Review {
  id        String   @id @default(cuid())
  peptideId String   @map("peptide_id")
  userId    String   @map("user_id")
  rating    Int      @db.SmallInt
  title     String   @db.VarChar(200)
  body      String   @db.Text
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  peptide Peptide @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One review per user per peptide
  @@unique([peptideId, userId])
  @@index([peptideId])
  @@index([userId])
  @@map("reviews")
}

// ── Finnrick integration models ─────────────────────────────────────────────

enum FinnrickGrade {
  A
  B
  C
  D
  E
}

/// Aggregate Finnrick rating for a specific vendor+peptide pair.
/// Raw Finnrick values — never modified by our scoring logic.
model FinnrickVendorRating {
  id              String        @id @default(cuid())
  vendorId        String        @map("vendor_id")
  peptideId       String        @map("peptide_id")
  grade           FinnrickGrade
  averageScore    Decimal       @db.Decimal(4, 1) @map("average_score")
  testCount       Int           @map("test_count")
  minScore        Decimal       @db.Decimal(4, 1) @map("min_score")
  maxScore        Decimal       @db.Decimal(4, 1) @map("max_score")
  oldestTestDate  DateTime      @map("oldest_test_date")
  newestTestDate  DateTime      @map("newest_test_date")
  finnrickUrl     String?       @map("finnrick_url")
  importBatchId   String        @map("import_batch_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  vendor  Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  peptide Peptide             @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  tests   FinnrickTestResult[]

  @@unique([vendorId, peptideId])
  @@index([peptideId])
  @@index([vendorId])
  @@index([grade])
  @@index([averageScore])
  @@map("finnrick_vendor_ratings")
}

/// Individual lab test result backing a FinnrickVendorRating.
model FinnrickTestResult {
  id                 String   @id @default(cuid())
  ratingId           String   @map("rating_id")
  testDate           DateTime @map("test_date")
  testScore          Decimal  @db.Decimal(4, 1) @map("test_score")
  advertisedQuantity Decimal  @db.Decimal(8, 2) @map("advertised_quantity")
  actualQuantity     Decimal  @db.Decimal(8, 2) @map("actual_quantity")
  quantityVariance   Decimal  @db.Decimal(6, 2) @map("quantity_variance")
  purity             Decimal  @db.Decimal(5, 2)
  batchId            String   @map("batch_id")
  containerType      String   @map("container_type")
  labId              String   @map("lab_id")
  source             String
  endotoxinsStatus   String?  @map("endotoxins_status")
  certificateLink    String?  @map("certificate_link")
  identityResult     String   @map("identity_result")
  importBatchId      String   @map("import_batch_id")
  createdAt          DateTime @default(now()) @map("created_at")

  rating FinnrickVendorRating @relation(fields: [ratingId], references: [id], onDelete: Cascade)

  @@index([ratingId])
  @@index([testDate])
  @@map("finnrick_test_results")
}

/// Audit trail for Finnrick data imports.
model FinnrickImport {
  id          String    @id @default(cuid())
  filename    String
  format      String
  recordCount Int       @default(0) @map("record_count")
  errorCount  Int       @default(0) @map("error_count")
  errors      String?   @db.Text
  importedBy  String?   @map("imported_by")
  status      String    @default("pending")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@index([status])
  @@map("finnrick_imports")
}

/// Maps our Vendor records to Finnrick vendor entries and configures scraping.
model VendorMapping {
  id               String   @id @default(cuid())
  vendorId         String   @unique @map("vendor_id")
  finnrickSlug     String   @unique @map("finnrick_slug")
  vendorDomain     String?  @map("vendor_domain")
  scrapingEnabled  Boolean  @default(false) @map("scraping_enabled")
  scrapingAdapter  String?  @map("scraping_adapter")
  rateLimit        Int      @default(10) @map("rate_limit")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([finnrickSlug])
  @@index([vendorDomain])
  @@map("vendor_mappings")
}

// ── News & content models ────────────────────────────────────────────────────

/// Configured news / RSS sources.  Only sources in this table (isActive=true)
/// will be fetched.  robots.txt compliance is recorded per-source so operators
/// can audit and toggle sources without re-checking.
model NewsSource {
  id              String    @id @default(cuid())
  name            String    @unique
  slug            String    @unique
  feedUrl         String    @map("feed_url")
  /// "rss" | "atom" (both handled by rss-parser)
  feedType        String    @default("rss") @map("feed_type")
  siteUrl         String    @map("site_url")
  isActive        Boolean   @default(true) @map("is_active")
  /// Whether robots.txt allows our crawler (stored after first check).
  robotsTxtAllows Boolean   @default(true) @map("robots_txt_allows")
  /// Minimum ms to wait between requests to this source.
  rateLimitMs     Int       @default(5000) @map("rate_limit_ms")
  description     String?
  lastFetchedAt   DateTime? @map("last_fetched_at")
  lastFetchStatus String?   @map("last_fetch_status")
  lastFetchError  String?   @db.Text @map("last_fetch_error")
  fetchCount      Int       @default(0) @map("fetch_count")
  errorCount      Int       @default(0) @map("error_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  articles NewsArticle[]

  @@index([isActive])
  @@map("news_sources")
}

/// A normalized news article ingested from a NewsSource.
/// source_url is the dedup key — re-ingesting the same URL is a no-op.
model NewsArticle {
  id            String    @id @default(cuid())
  sourceId      String    @map("source_id")
  title         String
  slug          String    @unique
  sourceUrl     String    @unique @map("source_url")
  excerpt       String?   @db.Text
  author        String?
  publishedAt   DateTime  @map("published_at")
  /// Peptide names, themes, and topic tags extracted from title/excerpt.
  tags          String[]
  isPinned      Boolean   @default(false) @map("is_pinned")
  isHidden      Boolean   @default(false) @map("is_hidden")
  isEditorsPick Boolean   @default(false) @map("is_editors_pick")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  source NewsSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([publishedAt(sort: Desc)])
  @@index([isHidden])
  @@index([isEditorsPick])
  @@map("news_articles")
}

/// Authored evergreen guide / tutorial pages shown in the "Learn" section.
model Guide {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String   @db.Text
  /// "basics" | "ratings" | "safety" | "vendors" | "research"
  category    String
  readingTime Int      @default(5) @map("reading_time")
  /// Display order within category
  order       Int      @default(0)
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isPublished])
  @@map("guides")
}
