// =============================================================================
// PeptidePal — Prisma Schema
// =============================================================================
// Run migrations:
//   npx prisma migrate dev --name init
//   npx prisma generate
//
// Production:
//   npx prisma migrate deploy
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth.js models (required by @auth/prisma-adapter) ───────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Core domain models ──────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts  Account[]
  sessions  Session[]
  reviews   Review[]
  protocols Protocol[]

  @@map("users")
}

model Vendor {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  website   String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  prices          PeptidePrice[]
  finnrickRatings FinnrickVendorRating[]
  vendorMapping   VendorMapping?
  editorialReview VendorReview?

  @@map("vendors")
}

model Peptide {
  id                  String   @id @default(cuid())
  name                String   @unique
  slug                String   @unique
  description         String?  @db.Text
  category            String?
  sequence            String?
  /// Molecular weight in Daltons
  molecularWeight     Float?   @map("molecular_weight")
  /// Human-readable half-life, e.g. "~5 days" or "2–4 hours"
  halfLife            String?  @map("half_life")
  /// e.g. "subcutaneous" | "intramuscular" | "oral" | "topical" | "intranasal"
  administrationRoute String?  @map("administration_route")
  /// fda-approved | investigational | research-chemical | compounded | approved-intl
  regulatoryStatus    String?  @map("regulatory_status")
  /// User-intent tags: weight-loss, muscle-growth, recovery, skin, longevity, etc.
  goalTags            String[] @map("goal_tags")
  /// Alternative names / trade names
  aliases             String[]
  /// Mechanism of action prose
  mechanismOfAction   String?  @map("mechanism_of_action") @db.Text
  /// JSON blob: { overview, researchContext, safetyNotes, references, hubNote, seeAlso }
  contentJson         String?  @map("content_json") @db.Text
  /// FK to PeptideCategory
  categoryId          String?  @map("category_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  peptideCategory  PeptideCategory?      @relation(fields: [categoryId], references: [id])
  prices           PeptidePrice[]
  reviews          Review[]
  finnrickRatings  FinnrickVendorRating[]
  interactionsA    PeptideInteraction[]  @relation("InteractionA")
  interactionsB    PeptideInteraction[]  @relation("InteractionB")
  pkProfiles       PharmacokineticProfile[]

  @@index([slug])
  @@index([name])
  @@index([categoryId])
  @@index([regulatoryStatus])
  @@map("peptides")
}

model PeptidePrice {
  id                 String   @id @default(cuid())
  peptideId          String   @map("peptide_id")
  vendorId           String   @map("vendor_id")
  price              Decimal  @db.Decimal(10, 2)
  currency           String   @default("USD") @db.VarChar(3)
  concentration      String
  sku                String
  productUrl         String   @map("product_url")
  availabilityStatus String   @default("in_stock") @map("availability_status")
  lastUpdated        DateTime @default(now()) @map("last_updated")
  createdAt          DateTime @default(now()) @map("created_at")

  peptide Peptide @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([peptideId, vendorId, sku])
  @@index([peptideId])
  @@index([vendorId])
  @@index([price])
  @@map("peptide_prices")
}

model Review {
  id        String   @id @default(cuid())
  peptideId String   @map("peptide_id")
  userId    String   @map("user_id")
  rating    Int      @db.SmallInt
  title     String   @db.VarChar(200)
  body      String   @db.Text
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  peptide Peptide @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One review per user per peptide
  @@unique([peptideId, userId])
  @@index([peptideId])
  @@index([userId])
  @@map("reviews")
}

// ── Finnrick integration models ─────────────────────────────────────────────

enum FinnrickGrade {
  A
  B
  C
  D
  E
}

/// Aggregate Finnrick rating for a specific vendor+peptide pair.
/// Raw Finnrick values — never modified by our scoring logic.
model FinnrickVendorRating {
  id             String        @id @default(cuid())
  vendorId       String        @map("vendor_id")
  peptideId      String        @map("peptide_id")
  grade          FinnrickGrade
  averageScore   Decimal       @map("average_score") @db.Decimal(4, 1)
  testCount      Int           @map("test_count")
  minScore       Decimal       @map("min_score") @db.Decimal(4, 1)
  maxScore       Decimal       @map("max_score") @db.Decimal(4, 1)
  oldestTestDate DateTime      @map("oldest_test_date")
  newestTestDate DateTime      @map("newest_test_date")
  finnrickUrl    String?       @map("finnrick_url")
  importBatchId  String        @map("import_batch_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  vendor  Vendor               @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  peptide Peptide              @relation(fields: [peptideId], references: [id], onDelete: Cascade)
  tests   FinnrickTestResult[]

  @@unique([vendorId, peptideId])
  @@index([peptideId])
  @@index([vendorId])
  @@index([grade])
  @@index([averageScore])
  @@map("finnrick_vendor_ratings")
}

/// Individual lab test result backing a FinnrickVendorRating.
model FinnrickTestResult {
  id                 String   @id @default(cuid())
  ratingId           String   @map("rating_id")
  testDate           DateTime @map("test_date")
  testScore          Decimal  @map("test_score") @db.Decimal(4, 1)
  advertisedQuantity Decimal  @map("advertised_quantity") @db.Decimal(8, 2)
  actualQuantity     Decimal  @map("actual_quantity") @db.Decimal(8, 2)
  quantityVariance   Decimal  @map("quantity_variance") @db.Decimal(6, 2)
  purity             Decimal  @db.Decimal(5, 2)
  batchId            String   @map("batch_id")
  containerType      String   @map("container_type")
  labId              String   @map("lab_id")
  source             String
  endotoxinsStatus   String?  @map("endotoxins_status")
  certificateLink    String?  @map("certificate_link")
  identityResult     String   @map("identity_result")
  importBatchId      String   @map("import_batch_id")
  createdAt          DateTime @default(now()) @map("created_at")

  rating FinnrickVendorRating @relation(fields: [ratingId], references: [id], onDelete: Cascade)

  @@index([ratingId])
  @@index([testDate])
  @@map("finnrick_test_results")
}

/// Audit trail for Finnrick data imports.
model FinnrickImport {
  id          String    @id @default(cuid())
  filename    String
  format      String
  recordCount Int       @default(0) @map("record_count")
  errorCount  Int       @default(0) @map("error_count")
  errors      String?   @db.Text
  importedBy  String?   @map("imported_by")
  status      String    @default("pending")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  @@index([status])
  @@map("finnrick_imports")
}

/// Maps our Vendor records to Finnrick vendor entries and configures scraping.
/// Also tracks per-source health metrics so the admin dashboard can surface
/// stale or erroring vendor data sources quickly.
///
/// TECH_NOTES — Health metrics:
///   lastScrapedAt    — set by the aggregator after each successful run
///   activeProducts   — count of in_stock prices for this vendor
///   scraperErrorCount — cumulative errors; reset when scraping re-activates
///   lastScraperError  — most recent error message for debugging
///   vendorType        — "research" | "cosmetic" | "pharmaceutical" | "catalog"
///   statusFlag        — "active" | "paused" | "manual-only" | "js-required" | "disabled"
model VendorMapping {
  id                String    @id @default(cuid())
  vendorId          String    @unique @map("vendor_id")
  finnrickSlug      String    @unique @map("finnrick_slug")
  vendorDomain      String?   @map("vendor_domain")
  scrapingEnabled   Boolean   @default(false) @map("scraping_enabled")
  scrapingAdapter   String?   @map("scraping_adapter")
  rateLimit         Int       @default(10) @map("rate_limit")
  notes             String?
  /// Vendor category: research | cosmetic | pharmaceutical | catalog
  vendorType        String    @default("research") @map("vendor_type")
  /// Operational status: active | paused | manual-only | js-required | disabled
  statusFlag        String    @default("active") @map("status_flag")
  // ── Health metrics (updated by aggregator) ─────────────────────────────
  lastScrapedAt     DateTime? @map("last_scraped_at")
  activeProducts    Int       @default(0) @map("active_products")
  scraperErrorCount Int       @default(0) @map("scraper_error_count")
  lastScraperError  String?   @map("last_scraper_error") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([finnrickSlug])
  @@index([vendorDomain])
  @@index([statusFlag])
  @@index([lastScrapedAt])
  @@map("vendor_mappings")
}

// ── Peptide interactions ─────────────────────────────────────────────────────

/// Known interactions between two peptides, used for safety checking
/// in the Protocol Builder.
model PeptideInteraction {
  id          String  @id @default(cuid())
  peptideAId  String  @map("peptide_a_id")
  peptideBId  String  @map("peptide_b_id")
  /// safe | caution | avoid
  severity    String
  description String  @db.Text
  source      String?
  peptideA    Peptide @relation("InteractionA", fields: [peptideAId], references: [id], onDelete: Cascade)
  peptideB    Peptide @relation("InteractionB", fields: [peptideBId], references: [id], onDelete: Cascade)

  @@unique([peptideAId, peptideBId])
  @@map("peptide_interactions")
}

// ── Protocols ───────────────────────────────────────────────────────────────

/// User-created peptide protocol (stack) with safety scoring and shareability.
model Protocol {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  goalTags    String[] @map("goal_tags")
  /// Ordered array of peptide IDs in this protocol
  peptideIds  String[] @map("peptide_ids")
  /// Computed from interactions (0–100)
  safetyScore Int?     @map("safety_score") @db.SmallInt
  isPublic    Boolean  @default(false) @map("is_public")
  creatorId   String?  @map("creator_id")
  /// nanoid token for shareable URLs
  shareToken  String?  @unique @map("share_token")
  viewCount   Int      @default(0) @map("view_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator User? @relation(fields: [creatorId], references: [id], onDelete: SetNull)

  @@index([isPublic])
  @@index([shareToken])
  @@map("protocols")
}

/// Curated combination protocol (editorial, not user-created).
model CombinationProtocol {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  displayName String   @map("display_name")
  description String   @db.Text
  goalTags    String[] @map("goal_tags")
  peptideIds  String[] @map("peptide_ids")
  rationale   String   @db.Text
  safetyNotes String   @map("safety_notes") @db.Text
  popularity  Int      @default(0)
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("combination_protocols")
}

// ── Pharmacokinetic profiles ────────────────────────────────────────────────

/// Published PK data for the Kinetics Lab visualizer.
model PharmacokineticProfile {
  id              String  @id @default(cuid())
  peptideId       String  @map("peptide_id")
  /// subcutaneous | intramuscular | oral
  routeOfAdmin    String  @map("route_of_admin")
  /// Hours to peak concentration
  tmax            Float
  /// Elimination half-life in hours
  halfLife        Float   @map("half_life")
  /// Bioavailability percentage (0–100)
  bioavailability Float?
  /// JSON array of { time: number, concentration: number } data points
  curveDataJson   String  @map("curve_data_json") @db.Text
  /// Citation for the PK data
  source          String

  peptide Peptide @relation(fields: [peptideId], references: [id], onDelete: Cascade)

  @@unique([peptideId, routeOfAdmin])
  @@map("pharmacokinetic_profiles")
}

// ── Articles & content ──────────────────────────────────────────────────────

/// Editorial article with MDX body stored in the database.
model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String    @db.Text
  /// MDX content stored as a string
  bodyMdx     String    @map("body_mdx") @db.Text
  /// investigation | education | technical | market
  category    String
  authorName  String    @map("author_name")
  authorBio   String?   @map("author_bio") @db.Text
  coverImage  String?   @map("cover_image")
  tags        String[]
  readingTime Int       @default(5) @map("reading_time")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([category])
  @@index([isPublished])
  @@index([publishedAt(sort: Desc)])
  @@map("articles")
}

/// Downloadable resource / lead magnet.
model LeadMagnet {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String   @db.Text
  /// Filename in /public/downloads/ or external URL
  fileName      String   @map("file_name")
  fileSize      Int      @map("file_size")
  coverImage    String?  @map("cover_image")
  downloadCount Int      @default(0) @map("download_count")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("lead_magnets")
}

// ── Verified Source Program ─────────────────────────────────────────────────

/// Application for the $99/yr Verified Source badge.
model VerifiedSourceApplication {
  id           String    @id @default(cuid())
  vendorId     String?   @map("vendor_id")
  providerId   String?   @map("provider_id")
  contactName  String    @map("contact_name")
  contactEmail String    @map("contact_email")
  /// pending | approved | rejected
  status       String    @default("pending")
  paidAt       DateTime? @map("paid_at")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@map("verified_source_applications")
}

// ── Manufacturing Partners (CDMO) ───────────────────────────────────────────

/// Contract Development and Manufacturing Organization.
model Cdmo {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  website       String?
  city          String?
  state         String?  @db.VarChar(2)
  description   String?  @db.Text
  /// API synthesis | fill-finish | lyophilization | analytical | formulation
  capabilities  String[]
  fdaRegistered Boolean  @default(false) @map("fda_registered")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([state])
  @@map("cdmos")
}

// ── Peptide categories ──────────────────────────────────────────────────────

model PeptideCategory {
  id           String            @id @default(cuid())
  name         String            @unique
  slug         String            @unique
  description  String?           @db.Text
  displayOrder Int               @default(0) @map("display_order")
  parentId     String?           @map("parent_id")
  parent       PeptideCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children     PeptideCategory[] @relation("CategoryTree")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  peptides Peptide[]

  @@map("peptide_categories")
}

// ── Provider directory ──────────────────────────────────────────────────────

/// Clinics, pharmacies (503A/503B), telehealth, and online vendors.
/// Distinct from Vendor (which represents research peptide vendors with scrapers).
model Provider {
  id               String    @id @default(cuid())
  name             String    @unique
  slug             String    @unique
  /// clinic | pharmacy_503a | pharmacy_503b | telehealth | online_vendor
  type             String
  website          String?
  phone            String?
  email            String?
  address          String?   @db.Text
  city             String?
  state            String?   @db.VarChar(2)
  zipCode          String?   @map("zip_code") @db.VarChar(10)
  country          String    @default("US") @db.VarChar(2)
  latitude         Float?
  longitude        Float?
  description      String?   @db.Text
  services         String[]
  acceptsInsurance Boolean   @default(false) @map("accepts_insurance")
  offersTelehealth Boolean   @default(false) @map("offers_telehealth")
  fdaRegistered    Boolean   @default(false) @map("fda_registered")
  cpsVerified      Boolean   @default(false) @map("cps_verified")
  lastVerifiedAt   DateTime? @map("last_verified_at")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([type])
  @@index([state])
  @@index([isActive])
  @@map("providers")
}

// ── Editorial vendor reviews ────────────────────────────────────────────────

/// Standardized editorial deep-dive reviews (distinct from user Review model).
model VendorReview {
  id              String   @id @default(cuid())
  vendorId        String   @unique @map("vendor_id")
  /// Scoring dimensions (1–10 scale)
  testingScore    Int      @map("testing_score") @db.SmallInt
  catalogScore    Int      @map("catalog_score") @db.SmallInt
  pricingScore    Int      @map("pricing_score") @db.SmallInt
  reputationScore Int      @map("reputation_score") @db.SmallInt
  shippingScore   Int      @map("shipping_score") @db.SmallInt
  paymentScore    Int      @map("payment_score") @db.SmallInt
  overallScore    Decimal  @map("overall_score") @db.Decimal(3, 1)
  summary         String   @db.Text
  /// JSON array of pros
  prosJson        String   @map("pros_json") @db.Text
  /// JSON array of cons
  consJson        String   @map("cons_json") @db.Text
  verdict         String   @db.Text
  authorName      String   @map("author_name")
  reviewDate      DateTime @map("review_date")
  isPublished     Boolean  @default(false) @map("is_published")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_reviews")
}

// ── News & content models ────────────────────────────────────────────────────

/// Configured news / RSS sources.  Only sources in this table (isActive=true)
/// will be fetched.  robots.txt compliance is recorded per-source so operators
/// can audit and toggle sources without re-checking.
model NewsSource {
  id              String    @id @default(cuid())
  name            String    @unique
  slug            String    @unique
  feedUrl         String    @map("feed_url")
  /// "rss" | "atom" (both handled by rss-parser)
  feedType        String    @default("rss") @map("feed_type")
  siteUrl         String    @map("site_url")
  isActive        Boolean   @default(true) @map("is_active")
  /// Whether robots.txt allows our crawler (stored after first check).
  robotsTxtAllows Boolean   @default(true) @map("robots_txt_allows")
  /// Minimum ms to wait between requests to this source.
  rateLimitMs     Int       @default(5000) @map("rate_limit_ms")
  description     String?
  lastFetchedAt   DateTime? @map("last_fetched_at")
  lastFetchStatus String?   @map("last_fetch_status")
  lastFetchError  String?   @map("last_fetch_error") @db.Text
  fetchCount      Int       @default(0) @map("fetch_count")
  errorCount      Int       @default(0) @map("error_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  articles NewsArticle[]

  @@index([isActive])
  @@map("news_sources")
}

/// A normalized news article ingested from a NewsSource.
/// source_url is the dedup key — re-ingesting the same URL is a no-op.
model NewsArticle {
  id            String   @id @default(cuid())
  sourceId      String   @map("source_id")
  title         String
  slug          String   @unique
  sourceUrl     String   @unique @map("source_url")
  excerpt       String?  @db.Text
  author        String?
  publishedAt   DateTime @map("published_at")
  /// Peptide names, themes, and topic tags extracted from title/excerpt.
  tags          String[]
  isPinned      Boolean  @default(false) @map("is_pinned")
  isHidden      Boolean  @default(false) @map("is_hidden")
  isEditorsPick Boolean  @default(false) @map("is_editors_pick")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  source NewsSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([publishedAt(sort: Desc)])
  @@index([isHidden])
  @@index([isEditorsPick])
  @@map("news_articles")
}

/// Authored evergreen guide / tutorial pages shown in the "Learn" section.
model Guide {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String   @db.Text
  /// "basics" | "ratings" | "safety" | "vendors" | "research"
  category    String
  readingTime Int      @default(5) @map("reading_time")
  /// Display order within category
  order       Int      @default(0)
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isPublished])
  @@map("guides")
}
